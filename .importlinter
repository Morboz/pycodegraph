[importlinter]
root_package = pycodegraph
include_external_packages = False

[importlinter:types-no-internal-imports]
name = types/C1: types must not import any pycodegraph module
type = forbidden
source_modules =
    pycodegraph.types
forbidden_modules =
    pycodegraph.db
    pycodegraph.config
    pycodegraph.codegraph
    pycodegraph.context
    pycodegraph.extraction
    pycodegraph.graph
    pycodegraph.resolution
    pycodegraph.search
    pycodegraph.integrations

[importlinter:config-no-internal-imports]
name = config/C1: config must not import any pycodegraph module
type = forbidden
source_modules =
    pycodegraph.config
forbidden_modules =
    pycodegraph.db
    pycodegraph.types
    pycodegraph.codegraph
    pycodegraph.context
    pycodegraph.extraction
    pycodegraph.graph
    pycodegraph.resolution
    pycodegraph.search
    pycodegraph.integrations

[importlinter:codegraph-no-reverse-deps]
name = codegraph/C1: core modules must not import codegraph
type = forbidden
source_modules =
    pycodegraph.db
    pycodegraph.config
    pycodegraph.types
    pycodegraph.context
    pycodegraph.extraction
    pycodegraph.graph
    pycodegraph.resolution
    pycodegraph.search
forbidden_modules =
    pycodegraph.codegraph

